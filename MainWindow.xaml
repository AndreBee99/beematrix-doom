<Window x:Class="beematrix_doom.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        xmlns:local="clr-namespace:beematrix_doom"
        mc:Ignorable="d"
        Title="BeeMatrix Doom Launcher" Height="700" Width="1100"
        Background="#0A0A0F" Foreground="#E0E0E5"
        WindowStartupLocation="CenterScreen" SnapsToDevicePixels="True"
        UseLayoutRounding="True">
    
    <Window.Resources>
        <!-- Cyber/Neon Theme Colors -->
        <SolidColorBrush x:Key="BgBrush" Color="#0A0A0F"/>
        <SolidColorBrush x:Key="CardBgBrush" Color="#101019"/>
        <SolidColorBrush x:Key="AccentYellow" Color="#FFE600"/>
        <SolidColorBrush x:Key="AccentCyan" Color="#00E5FF"/>
        <SolidColorBrush x:Key="AccentRed" Color="#FF2E93"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#1F1F35"/>
        <SolidColorBrush x:Key="TextMuted" Color="#7A7A8F"/>

        <!-- Custom Buttons -->
        <Style x:Key="CyberButton" TargetType="Button">
            <Setter Property="Background" Value="#151522"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#202030"/>
                                <Setter Property="BorderBrush" Value="{StaticResource AccentYellow}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="YellowButton" TargetType="Button" BasedOn="{StaticResource CyberButton}">
            <Setter Property="Background" Value="#FFE600"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="#FFE600"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#FFF54C"/>
                                <Setter Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#FFE600" BlurRadius="8" ShadowDepth="0"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RedButton" TargetType="Button" BasedOn="{StaticResource CyberButton}">
            <Setter Property="Background" Value="#FF2E93"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#FF2E93"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#FF5C9D"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Custom Input Styling -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#05050A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="CaretBrush" Value="{StaticResource AccentYellow}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="{StaticResource AccentCyan}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Card Borders -->
        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBgBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <!-- Game Pane (WebView2) -->
            <ColumnDefinition Width="*"/>
            <!-- Settings Dashboard -->
            <ColumnDefinition Width="380"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT COLUMN: EMBEDDED DOOM PLAYER -->
        <Border Grid.Column="0" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Background="Black" CornerRadius="8" ClipToBounds="True" Margin="0,0,15,0">
            <Grid>
                <!-- WebView2 Browser Control -->
                <wv2:WebView2 x:Name="WvDoomPlayer" 
                              Source="https://doom.poncet.dev/"
                              Focusable="True"
                              HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
                
                <!-- Game Focus Banner (Top Overlay) -->
                <Border VerticalAlignment="Top" HorizontalAlignment="Center" Background="#B0000000" CornerRadius="0,0,6,6" Padding="20,5" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1,0,1,1">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="8" Height="8" Fill="Green" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="CLICK INSIDE WINDOW &amp; USE KEYBOARD ARROWS / CTRL / SPACE TO PLAY" FontSize="10" FontWeight="Bold" Foreground="#8AECFF"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- RIGHT COLUMN: STREAM CONTROLLER -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <!-- Header -->
                <RowDefinition Height="Auto"/>
                <!-- Connection Block -->
                <RowDefinition Height="Auto"/>
                <!-- Stream Block -->
                <RowDefinition Height="Auto"/>
                <!-- Output Diagnostics -->
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header Panel -->
            <StackPanel Grid.Row="0" Margin="0,0,0,15">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="BEEMATRIX" FontSize="26" FontWeight="Black" Foreground="White"/>
                    <TextBlock Text=" DOOM" FontSize="26" FontWeight="Light" Foreground="{StaticResource AccentYellow}"/>
                </StackPanel>
                <TextBlock Text="Wasm DOOM stream companion for 32x32 LED panel" FontSize="11" Foreground="{StaticResource TextMuted}"/>
            </StackPanel>

            <!-- BLE Connection Block -->
            <Border Grid.Row="1" Style="{StaticResource CardBorder}">
                <StackPanel>
                    <TextBlock Text="BLUETOOTH LE CONNECTION" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextMuted}" Margin="0,0,0,12"/>
                    
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="MAC:" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="11" FontWeight="Bold"/>
                        <TextBox x:Name="TxtMacAddress" Grid.Column="1" Text="00:00:00:00:00:00" Margin="0,0,8,0" VerticalContentAlignment="Center" TextAlignment="Center" FontFamily="Consolas"/>
                        
                        <Ellipse x:Name="ElStatusIndicator" Grid.Column="2" Width="10" Height="10" Fill="Red" VerticalAlignment="Center"/>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button x:Name="BtnConnect" Content="CONNECT" Grid.Column="0" Margin="0,0,5,0" Style="{StaticResource YellowButton}" Click="BtnConnect_Click"/>
                        <Button x:Name="BtnDisconnect" Content="DISCONNECT" Grid.Column="1" Margin="5,0,0,0" Style="{StaticResource CyberButton}" Click="BtnDisconnect_Click" IsEnabled="False"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Streaming Toggle Block -->
            <Border Grid.Row="2" Style="{StaticResource CardBorder}">
                <StackPanel>
                    <TextBlock Text="DISPLAY STREAM CONTROLLER" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextMuted}" Margin="0,0,0,12"/>
                    <Button x:Name="BtnStream" Content="START STREAM" Style="{StaticResource CyberButton}" Click="BtnStream_Click" IsEnabled="False" Padding="15,12" FontSize="13"/>
                </StackPanel>
            </Border>

            <!-- Log Terminal -->
            <Border Grid.Row="3" Style="{StaticResource CardBorder}" Margin="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="TERMINAL STREAM DIAGNOSTICS" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextMuted}" Margin="0,0,0,8"/>
                    <TextBox x:Name="TxtLogTerminal" Grid.Row="1" IsReadOnly="True" 
                             FontFamily="Consolas" FontSize="11" Background="#05050A" 
                             BorderBrush="#1F1F35" Foreground="{StaticResource AccentCyan}" 
                             VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" 
                             AcceptsReturn="True" TextWrapping="Wrap"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
